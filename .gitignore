# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
.cache/

# Ignore the directory for local files during development
local/

# Ignore generated Ruby dependency files
Gemfile.lock

# Ignore files created by npm
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore the vendor file at root level and bundle for alternative installation
/vendor/
.bundle/

# Ignore local Codex files
.codex/

# Ignore folders related to IDEs
.vscode/
.idea/

# Ignore OS/editor files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
